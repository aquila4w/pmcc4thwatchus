# ===================================
# PAYLOAD CMS CONFIGURATION
# ===================================
PAYLOAD_SECRET=your-super-secret-payload-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production

# ===================================
# DATABASE CONFIGURATION (MongoDB)
# ===================================
# For local development, you can use:
# 1. MongoDB Atlas (cloud) - Get connection string from atlas.mongodb.com
# 2. Local MongoDB - mongodb://localhost:27017/pmcc4thwatch
MONGODB_URI=mongodb://localhost:27017/pmcc4thwatch

# ===================================
# SITE CONFIGURATION
# ===================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_MEDIA_URL=https://images.pmcc4thwatch.us

# ===================================
# OPTIONAL: THIRD-PARTY SERVICES
# ===================================
# SendGrid (for transactional emails)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Resend (alternative email service)
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=PMCC 4th Watch <events@pmcc4thwatch.us>

# Cron job authentication (cron job authentication)
CRON_SECRET=your-cron-secret-key-change-this-in-production

# Guest-to-member conversion temp password (required)
GUEST_TEMP_PASSWORD=your-secure-temp-password

# Google Maps API (for location features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# S3 Storage (for media uploads)
S3_ACCESS_KEY_ID=your-s3-access-key
S3_SECRET_ACCESS_KEY=your-s3-secret-key
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_ENDPOINT=https://s3.amazonaws.com
